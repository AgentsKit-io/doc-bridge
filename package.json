{
  "name": "@agentskit/doc-bridge",
  "version": "0.1.0-alpha.1",
  "description": "Agent-first documentation bridge for any project — OKF knowledge, AgentHandoff routing, doc site plugins.",
  "type": "module",
  "bin": {
    "ak-docs": "./bin/ak-docs.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "agentskit",
    "documentation",
    "mcp",
    "for-agents",
    "llms.txt",
    "agent-handoff"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentsKit-io/doc-bridge.git"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}