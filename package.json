{
  "name": "@agentskit/doc-bridge",
  "version": "0.0.0",
  "description": "Agent-first documentation bridge for any project — OKF knowledge, AgentHandoff routing, doc site plugins.",
  "type": "module",
  "bin": {
    "ak-docs": "./dist/bin/ak-docs.js"
  },
  "exports": {
