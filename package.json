{
  "name": "@agentskit/doc-bridge",
  "version": "1.0.2",
  "description": "Human↔agent documentation bridge — deterministic handoffs, doc-site links, memory→docs, optional AgentsKit RAG/chat.",
  "type": "module",
  "bin": {
    "ak-docs": "bin/ak-docs.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "action.yml",
    "scripts/prepare.mjs",
    "docs",
    "examples",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "LICENSE",
    "tsup.config.ts",
    "tsconfig.json",
    "src"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "smoke:packaged": "node scripts/smoke-packaged.mjs",
    "smoke:docsites": "node scripts/smoke-docsites.mjs",
    "smoke:real-docsites": "node scripts/smoke-real-docsites.mjs",
    "smoke:ollama": "node scripts/smoke-ollama.mjs",
    "coverage:badge": "node scripts/update-coverage-badge.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && npm test && changeset publish",
    "version": "node scripts/sync-version.mjs && git add package.json src/version.ts",
    "prepublishOnly": "npm run build && npm test",
    "prepare": "node scripts/prepare.mjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "agentskit",
    "documentation",
    "mcp",
    "for-agents",
    "llms-txt",
    "agent-handoff",
    "rag",
    "human-agent-bridge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/doc-bridge.git"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@agentskit/adapters": ">=0.12.0 <1",
    "@agentskit/core": ">=1.0.0 <2",
    "@agentskit/ink": ">=0.8.0 <1",
    "@agentskit/memory": ">=0.9.0 <1",
    "@agentskit/rag": ">=0.3.0 <1",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@agentskit/adapters": {
      "optional": true
    },
    "@agentskit/core": {
      "optional": true
    },
    "@agentskit/ink": {
      "optional": true
    },
    "@agentskit/memory": {
      "optional": true
    },
    "@agentskit/rag": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "4.1.10",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "author": "AgentsKit",
  "bugs": {
    "url": "https://github.com/AgentsKit-io/doc-bridge/issues"
  },
  "homepage": "https://agentskit-io.github.io/doc-bridge/"
}
