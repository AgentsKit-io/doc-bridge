          "capabilities": ["Tools", "RAG", "Memory", "MCP"],
          "steps": ["Choose any adapter", "Add tools and memory", "Ship without rewrites"]
        },
        "cta": "Build with AgentsKit",
        "ctaSurface": "docs"
