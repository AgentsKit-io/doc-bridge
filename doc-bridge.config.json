{
  "schemaVersion": 1,
  "corpus": {
    "agent": {
      "root": "docs",
      "index": "docs/getting-started.md"
    }
  },
  "routing": {
    "options": {
      "ownership": {
        "doc-bridge": {
          "path": "src",
